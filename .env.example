# Copy to .env and adjust if needed.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Resource names (created by infra/bootstrap.sh)
KMS_KEY_ALIAS=alias/ehr-cmk
S3_BUCKET=ehr-records
DDB_LEDGER_TABLE=AuditLedger
DDB_POLICY_TABLE=AccessPolicies
SECRET_NAME=ehr/jwt-signing-key
COGNITO_POOL_NAME=ehr-users
LAMBDA_SMART_CONTRACT=ehr-smart-contract
LAMBDA_AUDIT_APPENDER=ehr-audit-appender
API_GATEWAY_NAME=ehr-api
LOG_GROUP=/ehr/app

# Flask
FLASK_SECRET=dev-secret-change-me
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
